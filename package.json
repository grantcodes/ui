{
  "name": "@grantcodes/ui",
  "version": "2.0.0-beta.10",
  "description": "",
  "type": "module",
  "main": "dist/main.cjs",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "author": "grantcodes",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./styles/base.css": {
      "import": "./dist/css/base.css",
      "require": "./dist/css/base.css"
    },
    "./styles/themes/grantcodes.css": {
      "import": "./dist/css/themes/grantcodes.css",
      "require": "./dist/css/themes/grantcodes.css"
    },
    "./components/*": {
      "import": "./dist/components/*",
      "require": "./dist/components/*"
    },
    "./fonts/*": "./dist/fonts/*"
  },
  "scripts": {
    "build": "vite build",
    "watch": "rollup -c -w",
    "generate": "plop",
    "fix": "run-s fix:lint",
    "fix:lint": "npx @biomejs/biome format --write src",
    "test": "run-s test:lint test:unit",
    "test:lint": "npx @biomejs/biome lint src",
    "test:unit": "ava",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "license": "MIT",
  "dependencies": {
    "@grantcodes/style-dictionary": "^1.1.0",
    "@lit/react": "^1.0.7",
    "classnames": "^2.5.1",
    "lit": "^3.3.0",
    "react-dom": "^19.1.0",
    "sanitize.css": "^13.0.0",
    "shiki": "^3.7.0"
  },
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@babel/core": "^7.27.7",
    "@biomejs/biome": "2.0.6",
    "@grantcodes/commit": "^2.0.0",
    "@storybook/web-components-vite": "^9.0.14",
    "ava": "^6.4.0",
    "lucide-static": "^0.525.0",
    "npm-run-all": "^4.1.5",
    "plop": "^4.0.1",
    "rollup": "^4.44.1",
    "sass": "^1.89.2",
    "storybook": "^9.0.14",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "@storybook/addon-docs": "^9.0.14"
  },
  "files": [
    "dist/**/*",
    "CHANGELOG.md",
    "README.md",
    "LICENCE"
  ],
  "ava": {
    "typescript": {
      "compile": false,
      "rewritePaths": {
        "src/": "tmp/tests/"
      }
    }
  }
}
