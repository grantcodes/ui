{
	"name": "@grantcodes/ui",
	"version": "2.0.0-beta.10",
	"description": "",
	"type": "module",
	"main": "src/main.js",
	"module": "src/main.js",
	"types": "src/main.d.ts",
	"author": "grantcodes",
	"exports": {
		".": {
			"types": "./src/main.d.ts",
			"import": "./src/main.js"
		},
		"./icons": {
			"types": "./src/icons.d.ts",
			"import": "./src/icons.js"
		},
		"./styles/base.css": {
			"import": "./src/scss/base.css",
			"require": "./src/scss/base.css"
		},
		"./styles/themes/grantcodes.css": {
			"import": "./src/scss/themes/grantcodes.css",
			"require": "./src/scss/themes/grantcodes.css"
		},
		"./components/*": {
			"import": "./src/components/*",
			"require": "./src/components/*"
		},
		"./fonts/*": "./src/fonts/*"
	},
	"scripts": {
		"dev": "storybook dev -p 6006",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"generate": "plop",
		"cem": "cem analyze --config custom-elements-manifest.config.js --litelement",
		"fix": "run-s fix:lint",
		"fix:lint": "npx @biomejs/biome format --write src",
		"test": "run-s test:lint test:unit",
		"test:lint": "npx @biomejs/biome lint src",
		"test:unit": "ava"
	},
	"license": "MIT",
	"dependencies": {
		"@grantcodes/style-dictionary": "^1.1.0",
		"lit": "^3.3.1",
		"sanitize.css": "^13.0.0",
		"shiki": "^3.13.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.6",
		"@custom-elements-manifest/analyzer": "^0.10.10",
		"@grantcodes/commit": "^2.0.0",
		"@storybook/addon-docs": "^9.1.13",
		"@storybook/web-components": "^9.1.13",
		"@storybook/web-components-vite": "^9.1.13",
		"@wc-toolkit/cem-inheritance": "^1.2.2",
		"@wc-toolkit/cem-sorter": "^1.0.1",
		"@wc-toolkit/cem-validator": "^1.0.3",
		"@wc-toolkit/module-path-resolver": "^1.0.0",
		"@wc-toolkit/storybook-helpers": "^9.0.1",
		"lucide-static": "^0.546.0",
		"npm-run-all": "^4.1.5",
		"plop": "^4.0.4",
		"storybook": "^9.1.13",
		"vite": "^7.0.0"
	},
	"files": [
		"src/**/*",
		"custom-elements.json",
		"CHANGELOG.md",
		"README.md",
		"LICENCE"
	],
	"customElements": "custom-elements.json",
	"ava": {
		"extensions": {
			"js": true
		},
		"files": [
			"src/**/*.test.js"
		]
	}
}
