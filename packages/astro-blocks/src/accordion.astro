---
import { GrantCodesAccordion } from '@grantcodes/ui/components/accordion/index.js'

interface AccordionItem {
  title: string
  content: string
}

interface Props {
  items: AccordionItem[]
}

const { items } = Astro.props
---

<div class="accordion">
  <div class="container">
    <GrantCodesAccordion items={items}></GrantCodesAccordion>
  </div>
</div>

<style>
  .accordion {
    padding: 2rem 0;
  }

  .container {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem;
  }
</style>
