---
import { GrantCodesLogoCloud } from  '@grantcodes/ui/components/logo-cloud/index.js'

interface LogoItem {
  name: string
  src: string
  alt?: string
  href?: string
}

interface Props {
  title?: string
  logos: LogoItem[]
}

const { title, logos } = Astro.props
---

<GrantCodesLogoCloud
  title={title}
  logos={JSON.stringify(logos)}
></GrantCodesLogoCloud>
