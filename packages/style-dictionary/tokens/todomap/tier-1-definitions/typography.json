{
	"typography": {
		"font-family": {
			"system": {
				"value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif"
			},
			"quicksand": {
				"value": "Quicksand, {typography.font-family.system}"
			}
		},
		"font-size": {
			"3xl":     { "value": "calc(1rem * pow({typography.font-scale.default}, 5))" },
			"4xl":     { "value": "calc(1rem * pow({typography.font-scale.default}, 6))" },
			"5xl":     { "value": "calc(1rem * pow({typography.font-scale.default}, 7))" },
			"6xl":     { "value": "calc(1rem * pow({typography.font-scale.default}, 8))" },
			"7xl":     { "value": "calc(1rem * pow({typography.font-scale.default}, 9))" },
			"8xl":     { "value": "calc(1rem * pow({typography.font-scale.default}, 10))" },
			"display": { "value": "calc(1rem * pow({typography.font-scale.default}, 14))" }
		}
	}
}
