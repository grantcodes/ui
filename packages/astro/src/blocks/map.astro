---
import { GrantCodesMap } from '@grantcodes/ui/components/map/index.js'

interface Props {
  lat: number | string
  lng: number | string
  zoom?: number
  label?: string
  directionsUrl?: string
  height?: string
}

const { lat, lng, zoom = 14, label, directionsUrl, height } = Astro.props
---

<GrantCodesMap
  lat={String(lat)}
  lng={String(lng)}
  zoom={zoom}
  label={label}
  directions-url={directionsUrl}
  height={height}
  client:only
></GrantCodesMap>
