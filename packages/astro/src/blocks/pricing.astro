---
import { GrantCodesPricing } from '@grantcodes/ui/components/pricing/index.js'

interface PricingFeature {
  text: string
  included: boolean
}

interface PricingTier {
  name: string
  price: string
  period?: string
  description?: string
  features: PricingFeature[]
  cta: { label: string; href: string }
  highlighted?: boolean
}

interface Props {
  title?: string
  subtitle?: string
  tiers: PricingTier[]
}

const { title, subtitle, tiers } = Astro.props
---

<GrantCodesPricing
  title={title}
  subtitle={subtitle}
  tiers={JSON.stringify(tiers)}
></GrantCodesPricing>
