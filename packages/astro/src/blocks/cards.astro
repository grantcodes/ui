---
import { GrantCodesCard } from '@grantcodes/ui/components/card/index.js'
import { GrantCodesContainer } from '@grantcodes/ui/components/container/index.js'

interface CardItem {
  title: string
  description?: string
  image?: string
  href?: string
}

interface Props {
  cards: CardItem[]
}

const { cards } = Astro.props
---

<div class="cards">
  <GrantCodesContainer align="wide">
    <div class="cards__grid">
      {cards.map((card) => (
        <a href={card.href || '#'} class="card-link">
          <GrantCodesCard>
            {card.image && <img slot="header" src={card.image} alt="" class="card__image" />}
            <h3 class="card__title">{card.title}</h3>
            {card.description && <p class="card__description">{card.description}</p>}
          </GrantCodesCard>
        </a>
      ))}
    </div>
  </GrantCodesContainer>
</div>

<style>
  .cards {
    padding-block: var(--g-spacing-2xl);
  }

  .cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--g-spacing-xl);
  }

  .card-link {
    display: flex;
    flex-grow: 1;
    text-decoration: none;
    color: inherit;
  }

  .card-link:hover {
    translate: 0 -2px;
  }

  .card__image {
    width: 100%;
    height: 150px;
    object-fit: cover;
    display: block;
  }

  .card__title {
    margin: 0;
    font: var(--g-typography-h4-font);
  }
</style>
