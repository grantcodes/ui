---
import {
  GrantCodesAccordion,
  GrantCodesAccordionItem,
} from '@grantcodes/ui/components/accordion/index.js'

interface AccordionItem {
  title: string
  content?: string
  htmlContent?: string
}

interface Props {
  items: AccordionItem[]
}

const { items } = Astro.props
---

<div class="accordion">
  <div class="container">
    <GrantCodesAccordion client:visible>
      {items.map((item) => (
        <GrantCodesAccordionItem title={item.title}>
          {item.htmlContent != null
            ? <div set:html={item.htmlContent} />
            : item.content ?? ''}
        </GrantCodesAccordionItem>
      ))}
    </GrantCodesAccordion>
  </div>
</div>

<style>
  .accordion {
    padding: 2rem 0;
  }

  .container {
    width: 100%;
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem;
  }
</style>
