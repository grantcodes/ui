---
import { GrantCodesGallery } from '@grantcodes/ui/components/gallery/index.js'
import { GrantCodesGalleryImage } from '@grantcodes/ui/components/gallery/index.js'
import { GrantCodesContainer } from '@grantcodes/ui/components/container/index.js'

interface GalleryImage {
  src: string
  alt?: string
  caption?: string
}

interface Props {
  images: GalleryImage[]
  filmstrip?: boolean
  marquee?: boolean
}

const { images, filmstrip = false, marquee = false } = Astro.props
---

<div class:list={['gallery', { 'gallery--filmstrip': filmstrip }]}>
  {filmstrip ? (
    <GrantCodesGallery filmstrip={true} marquee={marquee}>
      {images.map((image) => (
        <GrantCodesGalleryImage src={image.src} alt={image.alt || ''} />
      ))}
    </GrantCodesGallery>
  ) : (
    <GrantCodesContainer align="wide">
      <GrantCodesGallery>
        {images.map((image) => (
          <GrantCodesGalleryImage src={image.src} alt={image.alt || ''} />
        ))}
      </GrantCodesGallery>
    </GrantCodesContainer>
  )}
</div>

<style>
  .gallery {
    padding-block: var(--g-spacing-2xl);
  }

  .gallery--filmstrip {
    padding-block: var(--g-spacing-xl);
    overflow: hidden;
  }
</style>
