---
import { GrantCodesGallery } from '@grantcodes/ui/components/gallery/index.js'
import { GrantCodesGalleryImage } from '@grantcodes/ui/components/gallery/index.js'

interface GalleryImage {
  src: string
  alt?: string
  caption?: string
}

interface Props {
  images: GalleryImage[]
  filmstrip?: boolean
  marquee?: boolean
}

const { images, filmstrip = false, marquee = false } = Astro.props
---

<div class:list={['gallery', { 'gallery--filmstrip': filmstrip }]}>
  {filmstrip ? (
    <GrantCodesGallery filmstrip={true} marquee={marquee}>
      {images.map((image) => (
        <GrantCodesGalleryImage src={image.src} alt={image.alt || ''} />
      ))}
    </GrantCodesGallery>
  ) : (
    <div class="container">
      <GrantCodesGallery>
        {images.map((image) => (
          <GrantCodesGalleryImage src={image.src} alt={image.alt || ''} />
        ))}
      </GrantCodesGallery>
    </div>
  )}
</div>

<style>
  .gallery {
    padding-block: 3rem;
  }

  .gallery--filmstrip {
    padding-block: 2rem;
    overflow: hidden;
  }

  .container {
    max-inline-size: 1400px;
    margin-inline: auto;
    padding-inline: 1rem;
  }
</style>
