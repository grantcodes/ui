---
import {GrantCodesStats} from '@grantcodes/ui/components/stats/index.js'

interface StatItem {
  label: string
  value: string
  context?: string
}

interface Props {
  title?: string
  items: StatItem[]
  columns?: number
}

const { title, items, columns = 4 } = Astro.props
---

<GrantCodesStats
  title={title}
  items={JSON.stringify(items)}
  columns={columns}
></GrantCodesStats>
