{
  "name": "@grantcodes/ui",
  "version": "2.1.1",
  "description": "A personal component system built with Lit web components",
  "type": "module",
  "main": "src/main.js",
  "module": "src/main.js",
  "types": "src/main.d.ts",
  "author": "grantcodes",
  "imports": {
    "#styles/*": "./src/lib/styles/*"
  },
  "exports": {
    ".": {
      "types": "./src/main.d.ts",
      "import": "./src/main.js"
    },
    "./icons": {
      "types": "./src/icons.d.ts",
      "import": "./src/icons.js"
    },
    "./styles/base.css": {
      "import": "./src/css/base.css",
      "require": "./src/css/base.css"
    },
    "./styles/themes/*": {
      "import": "./src/css/themes/*",
      "require": "./src/css/themes/*"
    },
    "./styles/focus-ring.css": "./src/lib/styles/focus-ring.styles.css",
    "./components/accordion/accordion.styles.css": "./src/components/accordion/accordion.styles.css",
    "./components/app-bar/app-bar.styles.css": "./src/components/app-bar/app-bar.styles.css",
    "./components/avatar/avatar.styles.css": "./src/components/avatar/avatar.styles.css",
    "./components/badge/badge.styles.css": "./src/components/badge/badge.styles.css",
    "./components/breadcrumb/breadcrumb.styles.css": "./src/components/breadcrumb/breadcrumb.styles.css",
    "./components/button/button.styles.css": "./src/components/button/button.styles.css",
    "./components/button-group/button-group.styles.css": "./src/components/button-group/button-group.styles.css",
    "./components/card/card.styles.css": "./src/components/card/card.styles.css",
    "./components/code-preview/code-preview.styles.css": "./src/components/code-preview/code-preview.styles.css",
    "./components/container/container.styles.css": "./src/components/container/container.styles.css",
    "./components/cta/cta.styles.css": "./src/components/cta/cta.styles.css",
    "./components/dialog/dialog.styles.css": "./src/components/dialog/dialog.styles.css",
    "./components/dropdown/dropdown.styles.css": "./src/components/dropdown/dropdown.styles.css",
    "./components/dropzone/dropzone.styles.css": "./src/components/dropzone/dropzone.styles.css",
    "./components/feature-list/feature-list.styles.css": "./src/components/feature-list/feature-list.styles.css",
    "./components/footer/footer.styles.css": "./src/components/footer/footer.styles.css",
    "./components/footer/footer-column.styles.css": "./src/components/footer/footer-column.styles.css",
    "./components/form-field/form-field.styles.css": "./src/components/form-field/form-field.styles.css",
    "./components/gallery/gallery.styles.css": "./src/components/gallery/gallery.styles.css",
    "./components/hero/hero.styles.css": "./src/components/hero/hero.styles.css",
    "./components/icon/icon.styles.css": "./src/components/icon/icon.styles.css",
    "./components/loading/loading.styles.css": "./src/components/loading/loading.styles.css",
    "./components/logo-cloud/logo-cloud.styles.css": "./src/components/logo-cloud/logo-cloud.styles.css",
    "./components/media-text/media-text.styles.css": "./src/components/media-text/media-text.styles.css",
    "./components/newsletter/newsletter.styles.css": "./src/components/newsletter/newsletter.styles.css",
    "./components/notice/notice.styles.css": "./src/components/notice/notice.styles.css",
    "./components/pagination/pagination.styles.css": "./src/components/pagination/pagination.styles.css",
    "./components/pricing/pricing.styles.css": "./src/components/pricing/pricing.styles.css",
    "./components/sidebar/sidebar.styles.css": "./src/components/sidebar/sidebar.styles.css",
    "./components/stats/stats.styles.css": "./src/components/stats/stats.styles.css",
    "./components/tabs/tabs.styles.css": "./src/components/tabs/tabs.styles.css",
    "./components/testimonials/testimonials.styles.css": "./src/components/testimonials/testimonials.styles.css",
    "./components/toast/toast.styles.css": "./src/components/toast/toast.styles.css",
    "./components/tooltip/tooltip.styles.css": "./src/components/tooltip/tooltip.styles.css",
    "./components/*": {
      "import": "./src/components/*",
      "require": "./src/components/*"
    },
    "./fonts/*": "./src/fonts/*"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "watch": "vite build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "npm run build-storybook",
    "generate": "plop",
    "cem": "cem analyze --config custom-elements-manifest.config.js --litelement",
    "fix": "run-s fix:lint",
    "fix:lint": "npx @biomejs/biome format --write src",
    "test": "run-s lint test:unit",
    "lint": "npx @biomejs/biome lint src",
    "test:unit": "NODE_ENV=test node --import @lit-labs/ssr-dom-shim/register-css-hook.js --test --test-concurrency=1 src/**/*.test.js"
  },
  "license": "MIT",
  "dependencies": {
    "@grantcodes/style-dictionary": "workspace:^",
    "lit": "^3.3.1",
    "sanitize.css": "^13.0.0",
    "shiki": "^3.17.1"
  },
  "devDependencies": {
    "@arcmantle/vite-plugin-import-css-sheet": "^1.0.12",
    "@biomejs/biome": "2.3.8",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@grantcodes/commit": "^2.0.0",
    "@lit-labs/ssr-dom-shim": "^1.5.1",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/addon-themes": "^10.1.4",
    "@storybook/web-components-vite": "^10.1.4",
    "@wc-toolkit/cem-inheritance": "^1.2.2",
    "@wc-toolkit/cem-sorter": "^1.0.1",
    "@wc-toolkit/cem-validator": "^1.0.3",
    "@wc-toolkit/module-path-resolver": "^1.0.0",
    "@wc-toolkit/storybook-helpers": "^10.0.0",
    "happy-dom": "^20.0.11",
    "lucide-static": "^0.555.0",
    "npm-run-all": "^4.1.5",
    "plop": "^4.0.4",
    "storybook": "^10.1.4",
    "vite": "^7.2.6"
  },
  "files": [
    "src/**/*",
    "custom-elements.json",
    "CHANGELOG.md",
    "README.md",
    "LICENCE"
  ],
  "customElements": "custom-elements.json"
}
