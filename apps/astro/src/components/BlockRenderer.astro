---
import {
  Accordion,
  Cards,
  Countdown,
  Cta,
  FeatureList,
  Gallery,
  Hero,
  LogoCloud,
  MapEmbed,
  MediaText,
  Newsletter,
  Pricing,
  Stats,
  Testimonials,
  Text,
} from '@grantcodes/astro/blocks'
import FormBlock from './blocks/FormBlock.astro'
import type { blockSchema } from '../lib/content/schema'

interface Props {
  block: typeof blockSchema._output
}

const { block } = Astro.props
---

{(() => {
  switch (block.type) {
    case 'hero':
      return (
        <Hero
          title={block.title}
          subtitle={block.subtitle}
          button={block.button}
          href={block.href}
          size={block.size}
          center={block.center}
          image={block.image}
        />
      )
    case 'text':
      return <Text content={block.content} />
    case 'gallery':
      return <Gallery images={block.images} />
    case 'accordion':
      return <Accordion items={block.items} />
    case 'cards':
      return <Cards cards={block.cards} />
    case 'cta':
      return (
        <Cta
          eyebrow={block.eyebrow}
          title={block.title}
          text={block.text}
          primaryAction={block.primaryAction}
          secondaryAction={block.secondaryAction}
          align={block.align}
        />
      )
    case 'feature-list':
      return (
        <FeatureList
          title={block.title}
          subtitle={block.subtitle}
          items={block.items}
          columns={block.columns}
        />
      )
    case 'stats':
      return (
        <Stats
          title={block.title}
          items={block.items}
          columns={block.columns}
        />
      )
    case 'logo-cloud':
      return (
        <LogoCloud
          title={block.title}
          logos={block.logos}
        />
      )
    case 'testimonials':
      return (
        <Testimonials
          title={block.title}
          items={block.items}
          layout={block.layout}
        />
      )
    case 'pricing':
      return (
        <Pricing
          title={block.title}
          subtitle={block.subtitle}
          tiers={block.tiers}
        />
      )
    case 'newsletter':
      return (
        <Newsletter
          title={block.title}
          text={block.text}
          action={block.action}
          method={block.method}
          placeholder={block.placeholder}
          buttonLabel={block.buttonLabel}
          disclaimer={block.disclaimer}
        />
      )
    case 'media-text':
      return (
        <MediaText
          title={block.title}
          text={block.text}
          media={block.media}
          reverse={block.reverse}
          cta={block.cta}
        />
      )
    case 'map':
      return (
        <MapEmbed
          lat={block.lat}
          lng={block.lng}
          zoom={block.zoom}
          label={block.label}
          directionsUrl={block.directionsUrl}
          height={block.height}
        />
      )
    case 'countdown':
      return (
        <Countdown
          target={block.target}
          daysLabel={block.daysLabel}
          hoursLabel={block.hoursLabel}
          minutesLabel={block.minutesLabel}
          secondsLabel={block.secondsLabel}
          pastMessage={block.pastMessage}
          showSeconds={block.showSeconds}
        />
      )
    case 'form':
      return (
        <FormBlock
          title={block.title}
          submitText={block.submitText}
          successMessage={block.successMessage}
          notifyEmail={block.notifyEmail}
          buttonText={block.buttonText}
        >
          <slot />
        </FormBlock>
      )
    default:
      return null
  }
})()}
