---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@i18n/utils'
import { GrantCodesAppBar } from '@grantcodes/ui/components/app-bar/index.js'
import { GrantCodesNavLink } from '@grantcodes/ui/components/app-bar/nav-link.js'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<GrantCodesAppBar sticky client:idle>
  <a href={translatePath('/')} slot="logo">
    <img src="/favicon.svg" alt="grant.codes" width="60" height="60" />
  </a>

  <ul slot="nav">
    <li>
      <GrantCodesNavLink>
        <a href={translatePath('/docs')}>{t('header.docs')}</a>
      </GrantCodesNavLink>
    </li>
    <li>
      <GrantCodesNavLink>
        <a href={translatePath('/blog')}>{t('header.blog')}</a>
      </GrantCodesNavLink>
    </li>
  </ul>
</GrantCodesAppBar>
