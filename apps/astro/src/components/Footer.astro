---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@i18n/utils'
import { GrantCodesFooter } from '@grantcodes/ui/components/footer/index.js'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<GrantCodesFooter>
  <div class="footer__info">
    <h4>
      <a href={getRelativeLocaleUrl('en', '')}>{t('footer.title')}</a>
    </h4>
    <p>{t('footer.description')}</p>
  </div>

  <nav slot="nav">
    <ul>
      <li><a href={getRelativeLocaleUrl('en', 'docs')}>Docs</a></li>
      <li>
        <a href={getRelativeLocaleUrl('en', 'resources')}>Resources</a>
      </li>
    </ul>
  </nav>

  <div slot="bottom" id="wcb" class="carbonbadge wcb-d"></div>
</GrantCodesFooter>

<script src="https://unpkg.com/website-carbon-badges@1.1.3/b.min.js" defer></script>

<style is:global>
  footer #wcb.carbonbadge {
    --b1: var(--g-theme-color-content-on-color);
    --b2: var(--g-theme-color-content-brand);
    text-align: inherit;
    width: fit-content;
  }

  footer #wcb #wcb_g {
    background-color: inherit;
    color: var(--g-theme-color-content-default);
  }
</style>
